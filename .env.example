NODE_ENV=development
APP_MODE=local
PORT=4000
WEB_PORT=5173
DATABASE_URL=./data/local.db
DEFAULT_EMAIL_PROVIDER=local
DEFAULT_MODEL_PROVIDER=mock
DEFAULT_SEND_PROVIDER=local
LOCAL_ONLY_MODE=true
ENABLE_REMOTE_MODELS=false
ENABLE_GMAIL_READ=false
ENABLE_GMAIL_DRAFTS=false
ENABLE_GMAIL_SEND=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_DEMO_LABEL=codex-demo
GMAIL_ALLOWLIST_SENDERS=
GMAIL_ALLOWLIST_RECIPIENTS=
# Keep DEFAULT_MODEL_PROVIDER=mock for the local sandbox. The seeded Gmail demo mailbox
# already uses the remote provider when ENABLE_REMOTE_MODELS=true.
REMOTE_MODEL_PROVIDER=gemini
REMOTE_MODEL_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
REMOTE_MODEL_BASE_URL=https://generativelanguage.googleapis.com/v1beta
REMOTE_MODEL_NAME=gemini-2.5-flash
MAX_INPUT_TOKENS=2500
MAX_OUTPUT_TOKENS=300
DAILY_GLOBAL_BUDGET_USD=10
DEFAULT_DRAFT_CONFIDENCE_THRESHOLD=0.8
DEFAULT_AUTOSEND_CONFIDENCE_THRESHOLD=0.97
WORKER_POLL_INTERVAL_MS=2000
APP_BASE_URL=http://localhost:4000
REVIEW_UI_BASE_URL=http://localhost:5173
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
